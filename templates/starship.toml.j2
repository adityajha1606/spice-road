# Auto-generated from palette.py by render.py — do not hand-edit
# ~/.config/starship.toml
# "Spice Road" — 60% Dune desert-mirage sci-fantasy, 40% Rajasthani bazaar maximalism
#
# Layout: three rows.
#   Row 1 (top, bronze frame)    — identity/context badges: where you are, what you're in
#   Row 2 (middle, bronze frame) — system pulse: live numbers, plain colored text
#   Row 3 (bottom, bronze frame) — the actual input line + right-aligned clock

add_newline = true
command_timeout = 1000

format = """
[┌─](fg:{{ styles.frame_color }})$directory$git_branch$git_status$python$nodejs$docker_context$aws$gcloud$azure$hostname
[│ ](fg:{{ styles.frame_color }})$jobs$memory_usage${custom.load}${custom.net_ok}${custom.net_down}${custom.battery}$cmd_duration$status
[└─](fg:{{ styles.frame_color }})$character"""

right_format = "$time"

# ---------- Row 1: context badges (filled pills) ----------

[directory]
style = "{{ styles.directory_style }}"
truncation_length = 3
truncate_to_repo = true
format = "[ $path ]($style)[$read_only]($read_only_style)"
read_only = " 🔒"
read_only_style = "{{ styles.directory_readonly }}"

[git_branch]
style = "{{ styles.git_branch_style }}"
format = "[ $symbol$branch ]($style)"

[git_status]
style = "{{ styles.git_status_style }}"
format = "[ $all_status$ahead_behind ]($style)"

[python]
style = "{{ styles.python_style }}"
format = "[ $symbol$pyenv_prefix($version)(\\($virtualenv\\)) ]($style)"

[nodejs]
style = "{{ styles.nodejs_style }}"
format = "[ $symbol($version) ]($style)"

[docker_context]
style = "{{ styles.docker_style }}"
format = "[ $symbol$context ]($style)"
only_with_files = true

[aws]
style = "{{ styles.aws_style }}"
format = "[ $symbol$profile ]($style)"
disabled = false

[gcloud]
style = "{{ styles.gcloud_style }}"
format = "[ $symbol$account ]($style)"
disabled = false

[azure]
style = "{{ styles.azure_style }}"
format = "[ $symbol$subscription ]($style)"
disabled = false

[hostname]
ssh_only = true
style = "{{ styles.hostname_style }}"
format = "[ ⇢ $hostname ]($style)"
disabled = false

# ---------- Row 2: system pulse (plain colored text) ----------

[jobs]
style = "{{ styles.jobs_style }}"
symbol = "⚙ "
number_threshold = 1
format = "[$symbol$number]($style) "

[memory_usage]
disabled = false
threshold = 60
style = "{{ styles.memory_style }}"
format = "[ $symbol$ram_pct]($style) "

[cmd_duration]
min_time = 2000
style = "{{ styles.cmd_duration_style }}"
format = "[⏱ $duration]($style) "

[status]
disabled = false
style = "{{ styles.status_style }}"
format = "[ ✗$status ]($style) "

[custom.load]
command = "uptime | awk -F'load average: ' '{print $2}' | awk -F',' '{print $1}' | xargs"
style = "{{ styles.load_style }}"
format = "[◆ $output]($style) "
shell = ["bash", "--norc"]

[custom.net_ok]
command = "echo ◆"
when = "ip route get 1.1.1.1 >/dev/null 2>&1"
style = "{{ styles.net_ok_style }}"
format = "[$output]($style) "
shell = ["bash", "--norc"]

[custom.net_down]
command = "echo ◇"
when = "! ip route get 1.1.1.1 >/dev/null 2>&1"
style = "{{ styles.net_down_style }}"
format = "[$output]($style) "
shell = ["bash", "--norc"]

[custom.battery]
command = "bash ~/.config/starship-helpers/battery.sh"
style = "{{ styles.battery_style }}"
format = "[$output]($style) "
shell = ["bash", "--norc"]

# ---------- Row 3: input line ----------

[character]
success_symbol = "[◈]({{ styles.character_success }})"
error_symbol = "[◈]({{ styles.character_error }})"
vimcmd_symbol = "[◈]({{ styles.character_vimcmd }})"

[time]
disabled = false
time_format = "%H:%M"
style = "{{ styles.time_style }}"
format = "[$time]($style)"